# Variables de entorno para el frontend (Vite)

# URL base del API (requerida)
VITE_API_URL=https://api.example.com/api

# URL base del backend sin /api (opcional: si no se define, se deriva de VITE_API_URL)
# VITE_BACKEND_URL=https://api.example.com

# URL base de WebSocket (opcional: si no se define, se deriva de VITE_BACKEND_URL)
# VITE_WS_URL=wss://api.example.com

# Modo de ejecución
VITE_NODE_ENV=production
